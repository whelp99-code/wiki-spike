{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiki-spike.local/schemas/phase3/projection-staging.schema.json",
  "title": "Phase 3 Projection Staging Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_id",
    "source_generation_id",
    "artifacts",
    "manifest_digest"
  ],
  "properties": {
    "schema_version": {"const": "phase3-projection-staging-v1"},
    "workspace_id": {"type": "string", "minLength": 1},
    "source_generation_id": {"type": "string", "minLength": 1},
    "manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "projection_name",
          "workspace_id",
          "source_generation_id",
          "schema_version",
          "required",
          "artifact_digest",
          "records_root",
          "record_count"
        ],
        "properties": {
          "projection_name": {"type": "string", "minLength": 1},
          "workspace_id": {"type": "string", "minLength": 1},
          "source_generation_id": {"type": "string", "minLength": 1},
          "schema_version": {"type": "string", "minLength": 1},
          "required": {"type": "boolean"},
          "artifact_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "records_root": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "record_count": {"type": "string", "pattern": "^(0|[1-9][0-9]*)$"}
        }
      }
    }
  }
}
