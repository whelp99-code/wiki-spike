{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiki-spike.local/schemas/phase3/registry-contracts.schema.json",
  "title": "Phase 3 Registry Contracts",
  "$defs": {
    "canonicalValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/canonicalValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/canonicalValue"}}
      ]
    },
    "versionedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_schema_version", "schema_family", "schema_version", "payload"],
      "properties": {
        "artifact_schema_version": {"const": "phase3-schema-artifact-v1"},
        "schema_family": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "pattern": "^[1-9][0-9]*$"},
        "payload": {"type": "object", "additionalProperties": {"$ref": "#/$defs/canonicalValue"}}
      }
    },
    "schemaDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_family", "schema_version", "schema_digest", "readable", "writable", "canonical_fixture_digest"],
      "properties": {
        "schema_family": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "pattern": "^[1-9][0-9]*$"},
        "schema_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "readable": {"const": true},
        "writable": {"type": "boolean"},
        "canonical_fixture_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "kindDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schema_family", "schema_version", "lifecycle_states", "built_in", "creatable", "definition_id"],
      "properties": {
        "kind": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"},
        "schema_family": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "pattern": "^[1-9][0-9]*$"},
        "lifecycle_states": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "built_in": {"type": "boolean"},
        "creatable": {"type": "boolean"},
        "definition_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "historicalPublicKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "algorithm", "public_key_b64", "purposes", "domains", "valid_from", "valid_until", "predecessor_key_id", "record_id"],
      "properties": {
        "key_id": {"type": "string", "minLength": 1},
        "algorithm": {"const": "ed25519"},
        "public_key_b64": {"type": "string", "minLength": 1},
        "purposes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "valid_from": {"type": "string", "minLength": 1},
        "valid_until": {"type": ["string", "null"]},
        "predecessor_key_id": {"type": ["string", "null"]},
        "record_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  },
  "oneOf": [
    {"$ref": "#/$defs/versionedArtifact"},
    {"$ref": "#/$defs/schemaDefinition"},
    {"$ref": "#/$defs/kindDefinition"},
    {"$ref": "#/$defs/historicalPublicKey"}
  ]
}
