{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/wiki-spike/phase2-storage-checkpoint.schema.json",
  "title": "Phase 2 Storage Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["checkpoint", "checkpoint_id"],
  "properties": {
    "checkpoint_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptance", "baseline_commit", "baseline_tree_listing_sha256",
        "baseline_tree_sha", "checkpoint_scope", "created_at",
        "public_key_sha256", "repository", "schema_version",
        "signer_key_id", "signing_domain", "test_evidence",
        "tracked_file_count"
      ],
      "properties": {
        "acceptance": {"type": "object"},
        "baseline_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "baseline_tree_listing_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "baseline_tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "checkpoint_scope": {"const": "phase2-storage"},
        "created_at": {"type": "string"},
        "public_key_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "repository": {"type": "string"},
        "schema_version": {"const": "phase2-storage-checkpoint-v1"},
        "signer_key_id": {"type": "string"},
        "signing_domain": {"const": "wiki.phase2.checkpoint.v1"},
        "test_evidence": {"type": "object"},
        "tracked_file_count": {"type": "string", "pattern": "^[0-9]+$"}
      }
    }
  }
}
